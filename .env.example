# Google OAuth client IDs for expo-auth-session.
# Create them in Google Cloud Console → APIs & Services → Credentials
# (OAuth client IDs of type iOS / Android / Web). Enable the Google Calendar API.
# Copy this file to `.env` and fill in the values you need; any one platform is enough to enable real login.
# Leave them empty/unset to keep using the built-in mock login.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional, DEV ONLY: Web OAuth client secret — enables token refresh ("stay logged in") on web.
# Insecure to embed in a client; only set it because web is used for development here.
# Native (iOS/Android) refreshes via PKCE and does NOT need this.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_SECRET=
